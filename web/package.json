{
  "name": "auroraops",
  "type": "module",
  "version": "2.18.6",
  "author": {
    "name": "MengShuai",
    "email": "133814250@qq.com",
    "url": "https://github.com/bufanyun/auroraops"
  },
  "private": true,
  "scripts": {
    "bootstrap": "pnpm install",
    "serve": "pnpm run dev",
    "dev": "vite",
    "build": "vite build && esno ./build/script/postBuild.ts",
    "build:no-cache": "pnpm clean:cache && pnpm run build",
    "report": "cross-env REPORT=true pnpm run build",
    "preview": "pnpm run build && vite preview",
    "preview:dist": "vite preview",
    "clean:cache": "rimraf node_modules/.cache/ && rimraf node_modules/.vite",
    "clean:lib": "rimraf node_modules",
    "deploy": "gh-pages -d dist",
    "lint:eslint": "eslint \"{src,mock}/**/*.{vue,ts,tsx}\" --fix",
    "lint:prettier": "prettier --write --loglevel warn \"src/**/*.{js,json,tsx,css,less,scss,vue,html,md}\"",
    "lint:stylelint": "stylelint --fix \"**/*.{vue,less,postcss,css,scss}\" --cache --cache-location node_modules/.cache/stylelint/",
    "lint:lint-staged": "lint-staged -c ./.husky/lintstagedrc.js",
    "lint:pretty": "pretty-quick --staged",
    "build typecheck": "vuedx-typecheck . && vite build",
    "test prod gzip": "http-server dist --cors --gzip -c-1"
  },
  "dependencies": {
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@fingerprintjs/fingerprintjs": "^5.2.0",
    "@vicons/antd": "^0.13.0",
    "@vicons/ionicons5": "^0.13.0",
    "@vue/runtime-core": "^3.5.35",
    "@vueup/vue-quill": "^1.2.0",
    "@vueuse/core": "^14.3.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "axios": "^1.16.1",
    "blueimp-md5": "^2.19.0",
    "codemirror": "^6.0.2",
    "date-fns": "^4.3.0",
    "echarts": "^6.1.0",
    "element-resize-detector": "^1.2.4",
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.1.1",
    "lodash-es": "^4.18.1",
    "mint-filter": "^4.0.3",
    "mitt": "^3.0.1",
    "naive-ui": "^2.44.1",
    "pinia": "^3.0.4",
    "pinyin-pro": "^3.28.1",
    "print-js": "^1.6.0",
    "qrcode.vue": "3.9.1",
    "qs": "^6.15.2",
    "quill-image-uploader": "^1.3.0",
    "quill-magic-url": "^4.2.0",
    "spark-md5": "^3.0.2",
    "throttle-debounce": "^5.0.2",
    "vfonts": "^0.0.3",
    "vue": "^3.5.35",
    "vue-i18n": "^11.4.4",
    "vue-router": "^5.1.0",
    "vue-types": "^6.0.0",
    "vue-waterfall-plugin-next": "^3.0.1",
    "vue3-json-viewer": "^2.4.1",
    "vuedraggable": "^4.1.0",
    "weixin-js-sdk": "^1.6.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/eslintrc": "^3.3.5",
