    "@vitejs/plugin-vue": "^6",
    "@vitejs/plugin-vue-jsx": "^5",
    "@vue/compiler-sfc": "^3.5.35",
    "@vue/eslint-config-typescript": "^14.7.0",
    "autoprefixer": "^10.5.0",
    "chalk": "^5.6.2",
    "commitizen": "^4.3.1",
    "core-js": "^3.49.0",
    "cross-env": "^10.1.0",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.1",
    "esno": "^4.8.0",
    "fs-extra": "^11.3.5",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "less": "^4.6.4",
    "less-loader": "^13.0.0",
