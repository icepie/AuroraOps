{
  "asar": false,
  "extraResources": [
    {
      "from": "go-client/bin/win32",
      "to": "go-agent/win32",
      "filter": [
        "**/*"
      ]
    },
    {
      "from": "go-client/bin/linux",
      "to": "go-agent/linux",
      "filter": [
        "**/*"
      ]
    },
    {
      "from": "go-client",
      "to": "go-agent",
      "filter": [
        "README.md",
        "auroraops-agent.service",
        "install-systemd.sh",
        "install-windows-service.ps1",
        "uninstall-windows-service.ps1"
      ]
    }
  ],
  "publish": [
    {
      "provider": "generic",
      "url": "http://127.0.0.1"
    }
  ],
  "productName": "AuroraOps Client",
  "appId": "org.auroraops.client",
  "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
  "directories": {
    "output": "build"
  },
  "files": ["dist/electron/**/*"],
  "dmg": {
    "contents": [
      {
        "x": 410,
        "y": 150,
        "type": "link",
        "path": "/Applications"
      },
      {
        "x": 130,
        "y": 150,
        "type": "file"
      }
    ]
  },
  "mac": {
    "icon": "build/icons/icon.icns"
  },
  "win": {
    "icon": "build/icons/icon.ico"
  },
  "linux": {
    "icon": "build/icons",
    "category": "Utility",
    "executableName": "auroraops-client",
    "target": ["deb", "rpm"]
  },
  "deb": {
    "packageName": "auroraops-client",
    "synopsis": "AuroraOps desktop client",
    "description": "AuroraOps desktop client with embedded Go agent for device binding, long connection, local HTTP UI, and hardware asset collection.",
    "maintainer": "AuroraOps <opensource@auroraops.local>",
    "vendor": "AuroraOps",
    "afterInstall": "packaging/linux/postinst.sh",
    "afterRemove": "packaging/linux/postrm.sh"
  },
  "rpm": {
    "packageName": "auroraops-client",
    "synopsis": "AuroraOps desktop client",
    "description": "AuroraOps desktop client with embedded Go agent for device binding, long connection, local HTTP UI, and hardware asset collection.",
    "maintainer": "AuroraOps <opensource@auroraops.local>",
    "vendor": "AuroraOps",
    "afterInstall": "packaging/linux/postinst.sh",
    "afterRemove": "packaging/linux/postrm.sh"
  }
}
