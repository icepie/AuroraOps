{
  "asar": false,
  "extraResources": [
    {
      "from": "go-client/bin/win32",
      "to": "go-agent/win32",
      "filter": [
        "**/*"
      ]
    },
    {
      "from": "go-client/bin/linux",
      "to": "go-agent/linux",
      "filter": [
        "**/*"
      ]
    },
    {
      "from": "go-client",
      "to": "go-agent",
      "filter": [
        "README.md",
        "auroraops-agent.service",
        "install-systemd.sh",
        "install-windows-service.ps1",
        "uninstall-windows-service.ps1"
      ]
    }
  ],
  "publish": [
    {
      "provider": "generic",
      "url": "http://127.0.0.1"
    }
  ],
  "productName": "AuroraOps Client",
  "appId": "org.auroraops.client",
  "artifactName": "auroraops-client-${version}-${os}-${arch}.${ext}",
  "directories": {
    "output": "build"
  },
  "files": ["dist/electron/**/*"],
  "dmg": {
    "contents": [
      {
        "x": 410,
        "y": 150,
        "type": "link",
        "path": "/Applications"
      },
      {
        "x": 130,
        "y": 150,
        "type": "file"
      }
    ]
  },
  "mac": {
    "icon": "build/icons/icon.icns"
  },
  "win": {
    "icon": "build/icons/icon.ico"
  },
  "linux": {
    "icon": "build/icons",
    "category": "Utility",
    "executableName": "auroraops-client",
    "target": ["deb", "rpm"]
  },
  "deb": {
    "packageName": "auroraops-client",
    "synopsis": "AuroraOps desktop client",
    "description": "AuroraOps desktop client with embedded Rust agent for device binding, terminal access, remote desktop control, local HTTP UI, and hardware asset collection.",
    "maintainer": "AuroraOps <opensource@auroraops.local>",
    "vendor": "AuroraOps",
    "depends": [
      "libgtk-3-0",
      "libnotify4",
      "libnss3",
      "libxss1",
      "xdg-utils",
      "libatspi2.0-0",
      "libuuid1",
      "libsecret-1-0",
      "libc6",
      "libgcc-s1 | libgcc1",
      "libx11-6",
      "libxext6",
      "libxrandr2",
      "libxfixes3",
      "libxcomposite1",
      "libxi6",
      "libxtst6",
      "libxinerama1",
      "libxcursor1",
      "libxkbcommon0",
      "libwayland-client0",
      "libwayland-cursor0",
      "libdbus-1-3",
      "libssl3 | libssl1.1",
      "libglib2.0-0",
      "libgstreamer1.0-0",
      "libgstreamer-plugins-base1.0-0",
      "libpango-1.0-0",
      "libcairo2",
      "libpangocairo-1.0-0",
      "libavformat62 | libavformat61 | libavformat60 | libavformat59 | libavformat58",
      "libavfilter11 | libavfilter10 | libavfilter9 | libavfilter8 | libavfilter7",
      "libavcodec62 | libavcodec61 | libavcodec60 | libavcodec59 | libavcodec58",
      "libavutil60 | libavutil59 | libavutil58 | libavutil57 | libavutil56",
      "libswscale9 | libswscale8 | libswscale7 | libswscale6 | libswscale5",
      "libswresample6 | libswresample5 | libswresample4 | libswresample3"
    ],
    "recommends": ["gstreamer1.0-plugins-base", "gstreamer1.0-pipewire", "libuinput-tools"],
    "afterInstall": "packaging/linux/postinst.sh",
    "afterRemove": "packaging/linux/postrm.sh"
  },
  "rpm": {
    "packageName": "auroraops-client",
    "synopsis": "AuroraOps desktop client",
    "description": "AuroraOps desktop client with embedded Rust agent for device binding, terminal access, remote desktop control, local HTTP UI, and hardware asset collection.",
    "maintainer": "AuroraOps <opensource@auroraops.local>",
    "vendor": "AuroraOps",
    "depends": [
      "gtk3",
      "libnotify",
      "nss",
      "libXScrnSaver",
      "(libXtst or libXtst6)",
      "xdg-utils",
      "at-spi2-core",
      "(libuuid or libuuid1)",
      "systemd",
      "ffmpeg-libs",
      "gstreamer1",
      "gstreamer1-plugins-base",
      "glib2",
      "dbus-libs",
      "openssl-libs",
      "pango",
      "cairo",
      "libX11",
      "libXext",
      "libXrandr",
      "libXfixes",
      "libXcomposite",
      "libXi",
      "libXtst",
      "libXinerama",
      "libXcursor",
      "libxkbcommon",
      "wayland"
    ],
    "afterInstall": "packaging/linux/postinst.sh",
    "afterRemove": "packaging/linux/postrm.sh"
  }
}
